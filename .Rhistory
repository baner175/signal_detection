library(truncdist)
library(VGAM)
library(doSNOW)
library(parallel)
library(foreach)
library(optparse)
##### SECTION 1: DEFINING DENSITIES AND FINDING KL-DIV MINIMIZER ###############
# search region
l <- 1; u <- 2
#parameters for the signal fs
mean_sig <- 1.28
sd_sig <- 0.06
# signal density
fs <- function(x, mean = mean_sig) dtrunc(x, a = l, b = u, spec = 'norm', mean = mean, sd = sd_sig)
#parameter for the true background
bkg_rate <- 3.3; bkg_shape <- 1.5 # parameters for fb
# true bkg density
fb_true <- function(x) dtrunc(x, a = l, b = u, spec = 'gamma',
rate = bkg_rate, shape = bkg_shape)
# true mixture density
f <- function(x) eta_true*fs(x)+(1-eta_true)*fb_true(x)
# The benchmark background model (denoted by q or \tilde{f}_b)
g <- function(x, beta, eps){
(1-eps) * dtrunc(x, spec = 'pareto', a = l, b = u,
scale = l, shape = beta) +
eps*dtrunc(x, a = l, b = u, spec = 'norm', mean = mean_sig, sd = sd_sig)
}
g <- Vectorize(g, vectorize.args = 'x')
S <- function(x, beta, eps){
fs <- fs(x)
g <- g(x, beta = beta, eps = eps)
return((fs/g - 1))
}
normS_integrand <- function(x, beta, eps){
fs <- dtrunc(x, a = l, b = u, spec = 'norm', mean = mean_sig, sd = sd_sig)
g <- (1-eps) * dtrunc(x, spec = 'pareto', a = l, b = u,
scale = l, shape = beta)
+ eps * dtrunc(x, a = l, b = u, spec = 'norm', mean = mean_sig, sd = sd_sig) # change q here
return(((fs/g-1)^2)*g)
}
# Minimizer of KL-divergence:
KL_div <- function(beta){
-integrate(function(x){
fb_val <- dtrunc(x, a = l, b = u, spec = 'gamma',
rate = bkg_rate, shape = bkg_shape)
g_val <- dtrunc(x, spec = 'pareto', a = l, b = u,
scale = l, shape = beta)
return(log(g_val)*fb_val)
}, l, u)$value
}
beta_star <- nlminb(start = 0.01,
objective = KL_div,
lower = 0, upper = 10)$par # parameter for q
curve(fb_true, l, u, lwd = 4, col = 'black',
ylab = 'Density',
xlab = 'x',
cex.lab = 2)
curve(g(x, beta = beta_star, eps = 0), add = TRUE, lwd = 4, col = 'orange',
lty = 2)
eps_ss <- 0.02 # example value of eps_max
curve(g(x, beta = beta_star, eps = eps_ss),
add = TRUE, lwd = 4, col = 'blue',
lty = 5)
legend('topright',
col = c('black', 'orange', 'blue'),
lty = c(1,2,5),
legend = c(TeX('$f_b$'),
TeX('$\\tilde{f}_b$'),
TeX('$\\tilde{g}$')),
lwd = 4,
bty = 'n', cex = 3)
rm(list = ls())
library(truncdist)
library(VGAM)
library(doSNOW)
library(parallel)
library(foreach)
library(optparse)
library(latex2exp)
##### SECTION 1: DEFINING DENSITIES AND FINDING KL-DIV MINIMIZER ###############
# search region
l <- 1; u <- 2
#parameters for the signal fs
mean_sig <- 1.28
sd_sig <- 0.06
# signal density
fs <- function(x, mean = mean_sig) dtrunc(x, a = l, b = u, spec = 'norm', mean = mean, sd = sd_sig)
#parameter for the true background
bkg_rate <- 3.3; bkg_shape <- 1.5 # parameters for fb
# true bkg density
fb_true <- function(x) dtrunc(x, a = l, b = u, spec = 'gamma',
rate = bkg_rate, shape = bkg_shape)
# true mixture density
f <- function(x) eta_true*fs(x)+(1-eta_true)*fb_true(x)
# The benchmark background model (denoted by q or \tilde{f}_b)
g <- function(x, beta, eps){
(1-eps) * dtrunc(x, spec = 'pareto', a = l, b = u,
scale = l, shape = beta) +
eps*dtrunc(x, a = l, b = u, spec = 'norm', mean = mean_sig, sd = sd_sig)
}
g <- Vectorize(g, vectorize.args = 'x')
S <- function(x, beta, eps){
fs <- fs(x)
g <- g(x, beta = beta, eps = eps)
return((fs/g - 1))
}
normS_integrand <- function(x, beta, eps){
fs <- dtrunc(x, a = l, b = u, spec = 'norm', mean = mean_sig, sd = sd_sig)
g <- (1-eps) * dtrunc(x, spec = 'pareto', a = l, b = u,
scale = l, shape = beta)
+ eps * dtrunc(x, a = l, b = u, spec = 'norm', mean = mean_sig, sd = sd_sig) # change q here
return(((fs/g-1)^2)*g)
}
# Minimizer of KL-divergence:
KL_div <- function(beta){
-integrate(function(x){
fb_val <- dtrunc(x, a = l, b = u, spec = 'gamma',
rate = bkg_rate, shape = bkg_shape)
g_val <- dtrunc(x, spec = 'pareto', a = l, b = u,
scale = l, shape = beta)
return(log(g_val)*fb_val)
}, l, u)$value
}
beta_star <- nlminb(start = 0.01,
objective = KL_div,
lower = 0, upper = 10)$par # parameter for q
curve(fb_true, l, u, lwd = 4, col = 'black',
ylab = 'Density',
xlab = 'x',
cex.lab = 2)
curve(g(x, beta = beta_star, eps = 0), add = TRUE, lwd = 4, col = 'orange',
lty = 2)
eps_ss <- 0.02 # example value of eps_max
curve(g(x, beta = beta_star, eps = eps_ss),
add = TRUE, lwd = 4, col = 'blue',
lty = 5)
legend('topright',
col = c('black', 'orange', 'blue'),
lty = c(1,2,5),
legend = c(TeX('$f_b$'),
TeX('$\\tilde{f}_b$'),
TeX('$\\tilde{g}$')),
lwd = 4,
bty = 'n', cex = 3)
####### SECTION 2: SIMULATION SEGMENT ###################################################
B <- 1e4 # Number of iterations
n_phys <- 2e3 # Size of the physics data
bkg_to_phys_ratio <- 1 # Bkg to physics sample ratio
n_bkg <- bkg_to_phys_ratio*n_phys # Size of the bkg data
eta_true <- 0 # true value of eta
beta0 <- beta_star # pre-specified value of beta, parameter for q
# window to search eps_max:
mu1 <- 1.26; mu2 <- 1.3
n_grid <- 10 # number of points in the grid to search eps_max
# Setting the grid to search eps_max:
mu_seq <- seq(mu1, mu2, length.out = n_grid)
# negative log-likelihood to estimate eps_max:
neg_ll_eps <- function(eps, mu, data){
fi <- eps*dtrunc(data, spec = 'norm', a = l, b = u,
mean = mu, sd = sd_sig) +
(1-eps)*dtrunc(data, spec = 'pareto', a = l, b = u,
scale = l, shape = beta0) # change q here
return(-sum(log(fi)))
}
solve_eps <- function(x, data){
nlminb(start = 0.01,
objective = neg_ll_eps,
lower = 0, upper = 1,
mu = x,
data = data)$par
}
# negative log-likelihood to estimate eta
neg_ll <- function(eta, eps, data){
fi <- eta*dtrunc(data, spec = 'norm', a = l, b = u,
mean = mean_sig, sd = sd_sig) +
(1-eta)*(
eps*dtrunc(data, spec = 'norm', a = l, b = u,
mean = mean_sig, sd = sd_sig)
+ (1-eps)*dtrunc(data, spec = 'pareto', a = l, b = u,
scale = l, shape = beta0)
) # change q here
return(-sum(log(fi)))
}
set.seed(12345)
seeds <- sample.int(.Machine$integer.max, B)
cl <- makeCluster(8) # parallelizing over 8 cores, change number of cores accordingly
registerDoSNOW(cl)
clusterExport(cl, ls(envir = environment()), envir = environment()) # exports the variables in the global envriorment of this scipt
clusterExport(cl, ls(envir = parent.frame()), envir = parent.frame()) # exports the global variables of a script when this script is sourced
# parameters for drawing progress bar:
pb <- txtProgressBar(max = B, style = 3)
progress <- function(n) setTxtProgressBar(pb, n)
opts <- list(progress = progress)
# starting simulations:
start_time <- Sys.time()
LRT_sim_res <- foreach(i = 1:B,
.packages = c('truncdist', 'VGAM'),
.options.snow = opts,
.combine = rbind) %dopar%
{
set.seed(seeds[i])
# sampling bkg data:
bkg_samp <- rtrunc(n_bkg, a = l, b = u, spec = 'gamma',
rate = bkg_rate, shape = bkg_shape)
# sampling physics data:
s_samp <- rtrunc(n_phys, a = l, b = u, spec = 'norm',
mean = mean_sig, sd = sd_sig)
b_samp <- rtrunc(n_phys, a = l, b = u, spec = 'gamma',
rate = bkg_rate, shape = bkg_shape)
u_mask <- runif(n_phys)
phys_samp <- ifelse(u_mask <= eta_true, s_samp, b_samp)
# estimating epsilon_hat's across the grid:
eps_hat_seq <- sapply(mu_seq, solve_eps, data = bkg_samp)
# eps_max:
eps_hat <- max(eps_hat_seq)
normS <- integrate(normS_integrand, beta = beta0, eps = eps_hat, l, u)$value |> sqrt()
delta_val <- integrate(function(x) S(x, beta = beta0, eps = eps_hat)*fb_true(x), l, u)$value/normS
eta_hat <- nlminb(start = 0.01,
objective = neg_ll,
lower = -1, upper = 1,
eps = eps_hat,
data = phys_samp)$par
eta_hat_C <- eta_hat*(eta_hat>0) # truncating eta_hat at 0
ll_eta_hat_C <- -neg_ll(eta = eta_hat_C, eps = eps_hat,
data = phys_samp)
ll_0 <- -neg_ll(eta = 0, eps = eps_hat,
data = phys_samp)
test_stat <- 2*(ll_eta_hat_C - ll_0)
c(delta_val, eta_hat_C, test_stat, eps_hat)
}
close(pb)
Sys.time() - start_time
stopCluster(cl)
###### SIMULATION ENDS #########################################################
LRT_sim_res <- as.data.frame(LRT_sim_res)
colnames(LRT_sim_res) <- c('delta', 'eta_hat', 'test_stat', 'eps_ss_hat')
# checking empirical P(Type I error)
alpha_val <- 0.05
q_val <- 2*(1-alpha_val)-1
mean(LRT_sim_res$test_stat > qchisq(q_val, df = 1))
